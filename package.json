{
  "name": "conectamos",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "build": "npm run prisma:generate && next build",
    "start": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "cron:efecty": "node scripts/railway-cron.mjs efecty",
    "cron:mora": "node scripts/railway-cron.mjs mora",
    "db:push": "npx prisma db push",
    "db:setup-aliados": "npx prisma db execute --file scripts/setup-aliado-conectamos.sql",
    "seed:initial": "npx prisma db execute --file scripts/seed-initial-data.sql",
    "prisma:generate": "npx prisma generate",
    "lint": "eslint"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@types/pdfkit": "^0.17.6",
    "heic2any": "^0.0.4",
    "lucide-react": "^0.468.0",
    "next": "16.2.3",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ssh2-sftp-client": "^12.1.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ssh2-sftp-client": "^9.0.6",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
